# Database (Railway MySQL)
DATABASE_URL="mysql://user:password@host:port/dbname"

# Better Auth
BETTER_AUTH_SECRET="ganti-dengan-random-string-panjang"
BETTER_AUTH_URL="http://localhost:3000"
# Dipakai di browser (lib/auth-client.ts) — HARUS diawali NEXT_PUBLIC_
# supaya kebawa ke client bundle. Isi sama dengan BETTER_AUTH_URL di atas.
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Akun Owner pertama, cuma dipakai sekali oleh prisma/seed.ts
# (nggak ada halaman signup — akun awal dibuat lewat seed).
SEED_OWNER_EMAIL="owner@sekolah.test"
SEED_OWNER_PASSWORD="ganti-password-ini"
SEED_OWNER_NAME="Owner Sekolah"

# Catatan: Midtrans Client Key/Server Key TIDAK di sini.
# Disimpan di tabel PengaturanPembayaran (lihat handoff bagian 3.4).
